rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the document belongs to the user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user is a collaborator
    function isCollaborator(collaborators) {
      return isAuthenticated() && (request.auth.uid in (collaborators || []));
    }

    // Attendance rules
    match /attendance/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId);
    }

    // Marks rules
    match /marks/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId);
    }

    // Todo / Tasks rules
    match /todos/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId);
    }

    // Assignments rules
    match /assignments/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId) || isCollaborator(resource.data.collaborators);
    }

    // Notes rules
    match /notes/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId) || isCollaborator(resource.data.collaborators);
    }

    // Exams rules
    match /exams/{docId} {
      allow read, write: if isOwner(resource.data.userId || request.resource.data.userId) || isCollaborator(resource.data.collaborators);
    }

    // Events rules
    match /events/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId || request.resource.data.userId);
      allow create: if isAuthenticated();
    }

    // Announcements rules (User specific for personal announcements, or global)
    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write globally (not implemented yet)
    }

    // Collaboration rules
    match /friendships/{docId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
    }

    match /collab_invites/{docId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || request.auth.uid == request.resource.data.senderId || request.auth.uid == request.resource.data.receiverId);
    }

    // User Profile rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
  }
}
